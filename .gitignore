# OS junk
.DS_Store

# Python
__pycache__/
*.pyc

# Per-company working state and deliverables live outside the plugin
# entirely, under ~/.report-generator/ (see skills/report-generator/SKILL.md) —
# using the skill should never write inside the plugin's own directory. These
# two rules are only a defensive backstop in case a bug ever writes them here
# anyway; they should normally never match anything.
skills/*/research_cache/
skills/*/output/

# Intermediate build artifacts from the visual-PDF assembly step (deleted
# after each run per SKILL.md, but ignored here as a backstop).
**/report.html
**/*.png
